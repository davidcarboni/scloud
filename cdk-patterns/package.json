{
  "name": "@scloud/cdk-patterns",
  "version": "0.11.3",
  "description": "Serverless CDK patterns for common infrastructure needs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "require": "./dist/*.js",
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "cdk-patterns": "./dist/deploy.sh"
  },
  "scripts": {
    "lint": "eslint --fix src",
    "compile": "tsc",
    "package": "yarn compile && cp deploy.sh dist/ && cp -r src/container src/edge src/express src/lambda dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidcarboni/scloud.git"
  },
  "keywords": [
    "AWS",
    "CDK",
    "Cloud",
    "Develoment",
    "Kit",
    "Serverless",
    "patterns"
  ],
  "author": "David Carboni",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/davidcarboni/scloud/issues"
  },
  "homepage": "https://github.com/davidcarboni/scloud#readme",
  "devDependencies": {
    "@eslint/js": "*",
    "@tsconfig/node24": "*",
    "@types/lodash": "*",
    "@types/node": "*",
    "aws-cdk": "*",
    "eslint": "*",
    "ts-node": "*",
    "typescript": "*",
    "typescript-eslint": "*"
  },
  "dependencies": {
    "@types/aws-lambda": "*",
    "aws-cdk-lib": "*",
    "aws-lambda": "*",
    "constructs": "*",
    "lodash": "*",
    "source-map-support": "*"
  }
}