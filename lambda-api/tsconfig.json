{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "types": [
      "node"
    ],
    "declaration": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "inlineSources": true,
    "inlineSourceMap": true,
    "outDir": "js",
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
  },
}